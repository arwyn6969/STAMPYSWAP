{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "outDir": ".tmp-test",
    "rootDir": ".",
    "types": ["node"],
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/lib/**/*.ts",
    "tests/**/*.ts"
  ]
}
